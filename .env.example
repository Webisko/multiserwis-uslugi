PUBLIC_ENABLE_ANALYTICS=false
SITE_ENVIRONMENT=preview
PUBLIC_SITE_URL=https://webisko.github.io
PUBLIC_SITE_BASE_PATH=/multiserwis-uslugi
PUBLIC_CONTACT_API_URL=
SITE_SETTINGS_API_URL=
FAQS_API_URL=
SERVICE_OFFERINGS_API_URL=
# Lokalny przykład przy uruchomionym backendzie Laravel:
# PUBLIC_CONTACT_API_URL=http://127.0.0.1:8081/api/v1/leads
# SITE_SETTINGS_API_URL=http://127.0.0.1:8081/api/v1/site-settings
# FAQS_API_URL=http://127.0.0.1:8081/api/v1/faqs
# SERVICE_OFFERINGS_API_URL=http://127.0.0.1:8081/api/v1/service-offerings
# Jeżeli endpointy settings/FAQ/services nie są ustawione, preview build spróbuje użyć snapshotów z src/generated/
# Produkcyjny przykład na VPS:
# SITE_ENVIRONMENT=production
# PUBLIC_SITE_URL=https://multiserwis.pl
# PUBLIC_SITE_BASE_PATH=/
