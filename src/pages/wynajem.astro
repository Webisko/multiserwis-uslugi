---
import Layout from "../layouts/Layout.astro";
import { Navbar } from "../components/Navbar";
import { Footer } from "../components/Footer";
import { RentalsPage } from "../screens/RentalsPage";
import { defaultCompany } from "../data/company";
import { getSiteSettings } from "../lib/siteSettings";

const companyData = (await getSiteSettings())?.company ?? defaultCompany;
---

<Layout
  title="Wynajem Maszyn Budowlanych | Multiserwis Kutno"
  description="Oferujemy wynajem podnośników koszowych, żurawi do 90t, ładowarek teleskopowych i wózków widłowych."
>
  <div>
    <Navbar client:load companyData={companyData} />
    <main class="flex-grow pt-[80px]">
      <RentalsPage companyData={companyData} />
    </main>
    <Footer companyData={companyData} />
  </div>
</Layout>
