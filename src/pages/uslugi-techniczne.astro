---
import Layout from "../layouts/Layout.astro";
import { Navbar } from "../components/Navbar";
import { Footer } from "../components/Footer";
---

<Layout
  title="Usługi Techniczne | Multiserwis Kutno"
  description="Przegląd usług technicznych: spawalnictwo, relokacja, konserwacja UDT."
>
  <div>
    <Navbar client:load />
    <main class="flex-grow pt-[80px] bg-industrial-950 min-h-screen py-20">
      <div class="container mx-auto px-4">
        <h1 class="text-4xl font-bold text-white mb-8">
          Usługi Techniczne
        </h1>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <a
            href="/spawanie"
            class="block bg-industrial-900 p-8 rounded border border-gray-800 hover:border-industrial-accent"
          >
            <h2 class="text-2xl font-bold text-white mb-2">Spawalnictwo</h2>
            <p class="text-gray-400">Usługi spawalnicze i konstrukcje.</p>
          </a>
          <a
            href="/udt"
            class="block bg-industrial-900 p-8 rounded border border-gray-800 hover:border-industrial-accent"
          >
            <h2 class="text-2xl font-bold text-white mb-2">
              Konserwacja UDT
            </h2>
            <p class="text-gray-400">Przeglądy i rejestracja urządzeń.</p>
          </a>
          <a
            href="/relokacja"
            class="block bg-industrial-900 p-8 rounded border border-gray-800 hover:border-industrial-accent"
          >
            <h2 class="text-2xl font-bold text-white mb-2">
              Relokacja Maszyn
            </h2>
            <p class="text-gray-400">
              Transport i montaż linii produkcyjnych.
            </p>
          </a>
        </div>
      </div>
    </main>
    <Footer />
  </div>
</Layout>
