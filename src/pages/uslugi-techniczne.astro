---
import Layout from "../layouts/Layout.astro";
import { Navbar } from "../components/Navbar";
import { Footer } from "../components/Footer";
import { ServiceInquiryCta } from "../components/ServiceInquiryCta";
import { defaultCompany } from "../data/company";
import { getSiteSettings } from "../lib/siteSettings";

const companyData = (await getSiteSettings())?.company ?? defaultCompany;
const basePath = companyData.links.basePath;
---

<Layout
  title="Usługi Techniczne | Multiserwis Kutno"
  description="Przegląd usług technicznych: spawalnictwo, relokacja, konserwacja UDT."
>
  <div>
    <Navbar client:load companyData={companyData} />
    <main class="flex-grow pt-[80px] bg-industrial-950 min-h-screen py-20">
      <div class="container mx-auto px-4">
        <div class="mb-12 max-w-3xl">
          <p class="mb-4 text-sm font-bold uppercase tracking-[0.22em] text-industrial-accent">Zakres usług</p>
          <h1 class="mb-6 text-4xl font-bold text-white md:text-5xl">Usługi Techniczne</h1>
          <p class="text-lg leading-relaxed text-gray-300">
            W jednym miejscu łączymy spawalnictwo, relokacje maszyn i obsługę UDT. Dzięki temu klient nie musi koordynować kilku wykonawców osobno dla prac mechanicznych, formalnych i transportowych.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <a
            href={`${basePath}/spawanie`}
            class="block rounded-2xl border border-gray-800 bg-industrial-900 p-8 transition-colors hover:border-industrial-accent"
          >
            <h2 class="mb-3 text-2xl font-bold text-white">Spawalnictwo</h2>
            <p class="text-gray-400">Naprawy, konstrukcje stalowe i realizacje niestandardowe dla zakładów i inwestycji przemysłowych.</p>
          </a>
          <a
            href={`${basePath}/udt`}
            class="block rounded-2xl border border-gray-800 bg-industrial-900 p-8 transition-colors hover:border-industrial-accent"
          >
            <h2 class="mb-3 text-2xl font-bold text-white">Konserwacja UDT</h2>
            <p class="text-gray-400">Rejestracja, formalności, badania techniczne i bieżąca obsługa urządzeń pod dozorem.</p>
          </a>
          <a
            href={`${basePath}/relokacja`}
            class="block rounded-2xl border border-gray-800 bg-industrial-900 p-8 transition-colors hover:border-industrial-accent"
          >
            <h2 class="mb-3 text-2xl font-bold text-white">Relokacja Maszyn</h2>
            <p class="text-gray-400">Demontaż, transport, ustawienie i rozruch pojedynczych maszyn oraz całych linii produkcyjnych.</p>
          </a>
        </div>

        <div class="mt-10">
          <ServiceInquiryCta
            title="Potrzebujesz wsparcia technicznego dopasowanego do konkretnego zadania?"
            description="Napisz, czy chodzi o relokację, spawanie, przygotowanie urządzeń do UDT albo pakiet kilku usług jednocześnie. Przygotujemy właściwy zakres prac i skierujemy zapytanie do odpowiedniego zespołu."
            contactLabel="Skonsultuj zakres prac"
            trainingTitle="Szkolenia branżowe"
            trainingDescription="W obszarach UDT, spawalnictwa i SEP prowadzimy także szkolenia na osobnej stronie, jeśli potrzebujesz podnieść kwalifikacje zespołu."
            companyData={companyData}
          />
        </div>
      </div>
    </main>
    <Footer companyData={companyData} />
  </div>
</Layout>
